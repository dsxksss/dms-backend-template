# 复制为 .env 用于本地开发（.env 不会被提交）。
# 所有变量都可覆盖 config/*.toml 中的同名项，前缀 DMS__，双下划线表示层级。

# 运行环境：local | cloud | onprem
APP_ENV=local

# 服务监听
DMS__SERVER__HOST=0.0.0.0
DMS__SERVER__PORT=8080

# 数据库（与 deploy/docker/docker-compose.yml 一致）
# 运行时：受 RLS 约束的应用角色 dms_app（多租户隔离生效的前提）
DMS__DATABASE__URL=postgres://dms_app:dms_app@127.0.0.1:5432/dms
# 迁移：拥有者角色 dms（具备 DDL 权限）
DMS__DATABASE__MIGRATION_URL=postgres://dms:dms@127.0.0.1:5432/dms
DMS__DATABASE__RUN_MIGRATIONS_ON_START=true
# sqlx-cli（migrate/prepare）直接读取 DATABASE_URL —— 用拥有者角色
DATABASE_URL=postgres://dms:dms@127.0.0.1:5432/dms

# 认证 / 会话（生产请用强随机值并通过密钥管理注入）
DMS__AUTH__JWT_SECRET=dev-only-change-me-please-32-bytes-min
DMS__AUTH__ACCESS_TTL_SECS=900
DMS__AUTH__REFRESH_TTL_SECS=1209600

# 可选：专有/既有平台令牌交换 provider（账号联动）。配置后即注册该外部身份源。
# DMS__AUTH__PLATFORM__NAME=demo-platform
# DMS__AUTH__PLATFORM__JWT_SECRET=change-me-platform-shared-secret
# DMS__AUTH__PLATFORM__ISSUER=

# bootstrap 子命令（创建初始租户+管理员）：dms-server bootstrap
BOOTSTRAP_TENANT_SLUG=acme
BOOTSTRAP_TENANT_NAME=Acme Inc
BOOTSTRAP_EMAIL=admin@acme.com
BOOTSTRAP_PASSWORD=change-me

# 日志级别
RUST_LOG=info,dms_=debug,sqlx=warn
